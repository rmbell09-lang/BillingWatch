[Unit]
Description=BillingWatch SSH Tunnel (VPS → Mac)
After=network.target

[Service]
Type=forking
ExecStart=/usr/bin/ssh -i /home/openclaw/.ssh/lucky_to_mac   -o IdentitiesOnly=yes   -o ServerAliveInterval=60   -o ServerAliveCountMax=3   -o ExitOnForwardFailure=yes   -L 0.0.0.0:8080:127.0.0.1:8000   -N -f luckyai@100.90.7.148
ExecStop=/bin/bash -c 'pkill -f "ssh.*8080.*luckyai@100.90.7.148"'
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
